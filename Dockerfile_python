FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install uv --no-cache-dir

# Copy project files
COPY pyproject.toml uv.lock ./
COPY server/ ./server/
COPY openenv.yaml ./
COPY inference.py ./
COPY README.md ./

# Install dependencies
RUN uv pip install --system fastapi uvicorn openai requests pydantic

# Expose HuggingFace Spaces port
EXPOSE 7860

ENV PORT=7860

CMD ["python", "-m", "uvicorn", "server.app:app", "--host", "0.0.0.0", "--port", "7860"]
